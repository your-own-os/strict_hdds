import os
import sys
import strict_hdds


def usage():
    print('Usage:')
    print('   strict_hdds show <directory>')
    print('   strict_hdds detect-and-mount <directory> [--read-only] [--extra-mount-options-for-rootfs=opt1,opt2...] [--extra-mount-options-for-boot=opt1,opt2...]')
    print('   strict_hdds create-and-mount <layout-name> <directory> [--disk-list=dev1,dev2...] [--read-only] [--extra-mount-options-for-rootfs=opt1,opt2...] [--extra-mount-options-for-boot=opt1,opt2...]')
    print('   strict_hdds add-harddisk <directory> <devpath>')
    print('   strict_hdds remove-harddisk <directory> <devpath>')
    print('   strict_hdds umount <directory>')
    print('')
    print('Supported layout:')
    for layoutName in strict_hdds.get_supported_storage_layout_names():
        print('   %s' % (layoutName))
    print('')


def die(msg):
    print(msg, file=sys.stderr)
    sys.exit(1)


def doShow():
    if len(sys.argv) < 2:
        die("No mount point directory specified!")
    layout = strict_hdds.get_storage_layout(sys.argv[1])
    _show(layout)


def doDetectAndMount():
    if len(sys.argv) < 2:
        die("No mount point directory specified!")
    kwargs = dict()
    for x in sys.argv[2:]:
        if x == "--read-only":
            kwargs["read_only"] = True
        if x.startswith("--extra_mount_options_for_rootfs="):
            kwargs["extra_mount_point_for_rootfs"] = x[len("--extra_mount_options_for_rootfs="):]
        if x.startswith("--extra_mount_options_for_boot="):
            kwargs["extra_mount_point_for_boot"] = x[len("--extra_mount_options_for_boot="):]
    layout = strict_hdds.detect_and_mount_storage_layout(sys.argv[1], **kwargs)
    _show(layout)


def doCreateAndMount():
    if len(sys.argv) < 2:
        die("No storage layout name specified!")
    if len(sys.argv) < 3:
        die("No mount point directory specified!")
    kwargs = dict()
    for x in sys.argv[3:]:
        if x.startswith("--disk-list="):
            kwargs["disk_list"] = x[len("--disk-list="):].split(",")
        if x == "--read-only":
            kwargs["read_only"] = True
        if x.startswith("--extra_mount_options_for_rootfs="):
            kwargs["extra_mount_point_for_rootfs"] = x[len("--extra_mount_options_for_rootfs="):]
        if x.startswith("--extra_mount_options_for_boot="):
            kwargs["extra_mount_point_for_boot"] = x[len("--extra_mount_options_for_boot="):]
    layout = strict_hdds.create_and_mount_storage_layout(sys.argv[1], sys.argv[2], **kwargs)
    _show(layout)


def doAddHarddisk():
    if len(sys.argv) < 2:
        die("No mount point directory specified!")
    if len(sys.argv) < 3:
        die("No harddisk device file specified!")
    layout = strict_hdds.get_storage_layout(sys.argv[1])
    if getattr(layout, "add_disk"):
        die("Operation is not supported by layout \"%s\"." % (layout.name))
    layout.add_disk(sys.argv[2])


def doRemoveHarddisk():
    if len(sys.argv) < 2:
        die("No mount point directory specified!")
    if len(sys.argv) < 3:
        die("No harddisk device file specified!")
    layout = strict_hdds.get_storage_layout(sys.argv[1])
    if getattr(layout, "remove_disk"):
        die("Operation is not supported by layout \"%s\"." % (layout.name))
    layout.remove_disk(sys.argv[2])


def doUmount():
    if len(sys.argv) < 2:
        die("No mount point directory specified!")
    layout = strict_hdds.get_storage_layout(sys.argv[1])
    layout.umount_and_dispose()


def _show(layout):
    if layout is None:
        print("Storage layout: empty")
        return

    if layout.name == "efi-bcachefs":
        if layout.get_ssd() is not None:
            ssdStr = layout.get_ssd()
            if layout.get_ssd_swap_partition() is not None:
                swapStr = "(with swap)"
            else:
                swapStr = ""
            bootDiskStr = ""
        else:
            ssdStr = "None"
            swapStr = ""
            bootDiskStr = " (boot disk: %s)" % (layout.boot_disk)
        print("Storage layout: %s, SSD: %s%s, HDDs: %s%s" % (layout.name, ssdStr, swapStr, " ".join(layout.get_hdd_list()), bootDiskStr))
        return

    if layout.name == "efi-bcache-btrfs":
        if layout.get_ssd() is not None:
            ssdStr = layout.get_ssd()
            if layout.get_ssd_swap_partition() is not None:
                swapStr = "(with swap)"
            else:
                swapStr = ""
            bootDiskStr = ""
        else:
            ssdStr = "None"
            swapStr = ""
            bootDiskStr = " (boot disk: %s)" % (layout.boot_disk)
        print("Storage layout: %s, SSD: %s%s, HDDs: %s%s" % (layout.name, ssdStr, swapStr, " ".join(layout.get_hdd_list()), bootDiskStr))
        return

    if layout.name == "efi-btrfs":
        if layout.get_ssd() is not None:
            bootDiskStr = ""
        else:
            bootDiskStr = " (boot disk: %s)" % (layout.boot_disk)
        print("Storage layout: %s, HDDs: %s%s" % (layout.name, " ".join(layout.get_hdd_list()), bootDiskStr))
        return

    if layout.name == "efi-ext4":
        if layout.dev_swap is not None:
            swapStr = " (with swap)"
        else:
            swapStr = ""
        print("Storage layout: %s, HDD: %s%s" % (layout.name, layout.boot_disk, swapStr))
        return

    if layout.name == "bios-ext4":
        if layout.dev_swap is not None:
            swapStr = " (with swap)"
        else:
            swapStr = ""
        print("Storage layout: %s, HDD: %s%s" % (layout.name, layout.boot_disk, swapStr))
        return

    assert False


if __name__ == '__main__':
    if len(sys.argv) <= 1:
        usage()
        sys.exit(1)

    if sys.argv[1] == "--help":
        usage()
        sys.exit(0)

    if os.getuid() != 0:
        die("You must run this command as root!")

    op = sys.argv[1]
    if op == "show":
        doShow()
    elif op == "create-and-mount":
        doDetectAndMount()
    elif op == "detect-and-mount":
        doCreateAndMount()
    elif op == "add-harddisk":
        doAddHarddisk()
    elif op == "remove-harddisk":
        doRemoveHarddisk()
    elif op == "umount":
        doUmount()
    else:
        die('Invalid operation.')




